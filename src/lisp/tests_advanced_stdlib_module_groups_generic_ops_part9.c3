module lisp;

fn void run_advanced_collections_generic_ops_part9(Interp* interp, int* pass, int* fail) {
    test_truthy(interp, "nn/forward runs train-mode dense model without hidden state mutation",
        "(let (model (nn/init (nn/dense 2 1 (Dictionary 'kernel-init (Dictionary 'kind 'ones) 'bias-init (Dictionary 'kind 'zeros))) (Dictionary 'dtype 'Float32 'device 'cpu 'mode 'train 'seed 1)) out (nn/forward model (Tensor Float32 [2] [1 2]))) (and (= (ref out [0]) (Float32 3.0)) (= (nn/mode model) 'train)))", pass, fail);
    test_truthy(interp, "nn/grad lifts dense activation gradients into sequential parameter tree",
        "(let (model (nn/init (nn/sequential (nn/dense 2 1 (Dictionary 'kernel-init (Dictionary 'kind 'ones) 'bias-init (Dictionary 'kind 'zeros))) (nn/relu)) (Dictionary 'dtype 'Float64 'device 'cpu 'mode 'train 'seed 1)) g (nn/grad model (Tensor Float64 [2] [1 2]) (Tensor Float64 [1] [4])) tree (ref g 'parameter-gradients) dense (ref tree 0) act (ref tree 1)) (and (= (ref g 'kind) 'nn-gradients) (= (ref g 'loss-kind) 'mean-squared-error) (= (length act) 0) (= (ref (ref dense 'weights) [0 0]) -2.0) (= (ref (ref dense 'weights) [0 1]) -4.0) (= (ref (ref dense 'bias) [0]) -2.0)))", pass, fail);
    test_truthy(interp, "nn/grad defaults softmax output layer to cross entropy",
        "(let (model (nn/init (nn/dense 1 2 (Dictionary 'activation 'softmax 'kernel-init (Dictionary 'kind 'zeros) 'bias-init (Dictionary 'kind 'zeros))) (Dictionary 'dtype 'Float32 'device 'cpu 'mode 'train 'seed 1)) g (nn/grad model (Tensor Float32 [1] [1]) (Tensor Float32 [2] [1 0])) pg (ref g 'parameter-gradients)) (and (= (ref g 'source) 'linear-softmax-cross-entropy) (= (ref g 'loss-kind) 'softmax-cross-entropy) (< (abs (- (ref (ref g 'loss) []) (Float32 0.69314718))) (Float32 0.0001)) (= (ref (ref pg 'weights) [0 0]) (Float32 -0.5)) (= (ref (ref pg 'bias) [1]) (Float32 0.5))))", pass, fail);
    test_truthy(interp, "nn/train-step returns updated model and optimizer state data",
        "(let (model (nn/init (nn/dense 2 1 (Dictionary 'kernel-init (Dictionary 'kind 'ones) 'bias-init (Dictionary 'kind 'zeros))) (Dictionary 'dtype 'Float64 'device 'cpu 'mode 'train 'seed 1)) step (nn/train-step model (Tensor Float64 [2] [1 2]) (Tensor Float64 [1] [4]) (Dictionary 'kind 'sgd 'learning-rate 0.1 'momentum 0.9) (Dictionary)) next (ref step 'model) weights (ref (ref (nn/parameters next) 'weights) [0 0]) velocity (ref (ref (ref step 'optimizer-state) 'velocity) 'weights)) (and (= (ref step 'kind) 'train-step) (= (nn/mode next) 'train) (< (abs (- weights 1.2)) 0.000000001) (= (ref velocity [0 0]) -2.0) (= (ref (ref step 'loss) []) 1.0)))", pass, fail);
    test_truthy(interp, "nn optimizer constructors produce ordinary optimizer specs",
        "(let (sgd (nn/sgd 0.1 (Dictionary 'momentum 0.9 'clip-norm 1.0)) adam (nn/adam 0.001 (Dictionary 'beta1 0.8 'beta2 0.99 'epsilon 0.000001 'weight-decay 0.01)) adamw (nn/adamw 0.001 (Dictionary 'weight-decay 0.1)) rms (nn/rmsprop 0.01 (Dictionary 'alpha 0.5 'momentum 0.2))) (and (= (ref sgd 'kind) 'sgd) (= (ref sgd 'learning-rate) 0.1) (= (ref sgd 'momentum) 0.9) (= (ref sgd 'clip-norm) 1.0) (= (ref adam 'kind) 'adam) (= (ref adam 'beta1) 0.8) (= (ref adam 'beta2) 0.99) (= (ref adam 'epsilon) 0.000001) (= (ref adamw 'kind) 'adamw) (= (ref adamw 'weight-decay) 0.1) (= (ref rms 'kind) 'rmsprop) (= (ref rms 'alpha) 0.5) (= (ref rms 'momentum) 0.2)))", pass, fail);
    test_truthy(interp, "nn optimizer constructors validate ranges and option keys",
        "(and (= (handle (nn/sgd -0.1) (raise msg (ref msg 'code))) 'nn/invalid-spec) (= (handle (nn/sgd 0.1 (Dictionary 'beta1 0.9)) (raise msg (ref msg 'code))) 'nn/invalid-spec) (= (handle (nn/adam 0.001 (Dictionary 'beta1 1.0)) (raise msg (ref msg 'code))) 'nn/invalid-spec) (= (handle (nn/adamw 0.001 (Dictionary 'epsilon 0.0)) (raise msg (ref msg 'code))) 'nn/invalid-spec) (= (handle (nn/rmsprop 0.01 (Dictionary 'alpha 1.0)) (raise msg (ref msg 'code))) 'nn/invalid-spec))", pass, fail);
    test_truthy(interp, "nn/train-step accepts constructed optimizer specs",
        "(let (model (nn/init (nn/dense 2 1 (Dictionary 'kernel-init (Dictionary 'kind 'ones) 'bias-init (Dictionary 'kind 'zeros))) (Dictionary 'dtype 'Float64 'device 'cpu 'mode 'train 'seed 1)) step (nn/train-step model (Tensor Float64 [2] [1 2]) (Tensor Float64 [1] [4]) (nn/sgd 0.1 (Dictionary 'momentum 0.9)) (Dictionary)) weights (ref (ref (nn/parameters (ref step 'model)) 'weights) [0 0])) (< (abs (- weights 1.2)) 0.000000001))", pass, fail);
    test_truthy(interp, "nn/grad and nn/train-step reject eval mode and unsupported Vulkan backward",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (and (= (handle (nn/grad (nn/init (nn/dense 1 1) (Dictionary 'dtype 'Float32 'device 'cpu 'mode 'eval)) (Tensor Float32 [1] [1]) (Tensor Float32 [1] [1])) (raise msg (ref msg 'code))) 'nn/invalid-spec) (if (ref vulkan-backend 'float32) (= (handle (nn/grad (nn/init (nn/dense 1 1) (Dictionary 'dtype 'Float32 'device 'vulkan 'mode 'train)) (to-device (Tensor Float32 [1] [1]) 'vulkan) (Tensor Float32 [1] [1])) (raise msg (ref msg 'code))) 'tensor/backend-unsupported) true)))", pass, fail);
    test_truthy(interp, "ml/clip-gradients scales Float64 gradient trees by max norm",
        "(let (g (Dictionary 'w (Tensor Float64 [2] [3 4]) 'b (Tensor Float64 [1] [0])) out (ml/clip-gradients g 2.5)) (and (< (abs (- (ref (ref out 'w) [0]) 1.5)) 0.000000001) (< (abs (- (ref (ref out 'w) [1]) 2.0)) 0.000000001) (= (ref (ref out 'b) [0]) 0.0)))", pass, fail);
    test_truthy(interp, "ml/clip-gradients preserves under-norm trees",
        "(let (g (Array (Dictionary 'w (Tensor Float32 [1] [0.25]))) out (ml/clip-gradients g 1.0)) (= (ref (ref (ref out 0) 'w) [0]) (Float32 0.25)))", pass, fail);
    test_truthy(interp, "ml/clip-gradients clips all-Vulkan dense row-major Float32 trees",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (if (and (ref vulkan-backend 'float32) (ref vulkan-backend 'ml-clip-gradients-float32)) (let (out (ml/clip-gradients (Dictionary 'w (to-device (Tensor Float32 [2] [3 4]) 'vulkan)) 2.5) w (to-device (ref out 'w) 'cpu)) (and (= (device (ref out 'w)) 'vulkan) (< (abs (- (ref w [0]) (Float32 1.5))) (Float32 0.000001)) (< (abs (- (ref w [1]) (Float32 2.0))) (Float32 0.000001)))) true))", pass, fail);
    test_truthy(interp, "ml/optimizer-step clip-norm applies before SGD update",
        "(let (r (ml/optimizer-step (Dictionary 'kind 'sgd 'learning-rate 1.0 'clip-norm 1.0) (Dictionary 'w (Tensor Float64 [2] [10 10])) (Dictionary 'w (Tensor Float64 [2] [3 4])) (Dictionary)) p (ref (ref r 'parameters) 'w)) (and (< (abs (- (ref p [0]) 9.4)) 0.000000001) (< (abs (- (ref p [1]) 9.2)) 0.000000001)))", pass, fail);
    test_truthy(interp, "ml/clip-gradients validates max norm and Vulkan fallback",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (and (= (handle (ml/clip-gradients (Dictionary 'w (Tensor Float64 [1] [1])) -1.0) (raise msg (ref msg 'code))) 'type/arg-mismatch) (= (handle (ml/clip-gradients (Dictionary 'w 1) 1.0) (raise msg (ref msg 'code))) 'tensor/invalid-argument) (if (ref vulkan-backend 'float32) (= (handle (ml/clip-gradients (Dictionary 'w (to-device (Tensor Float32 [1] [1]) 'vulkan) 'b (Tensor Float32 [1] [0.2])) 1.0) (raise msg (ref msg 'code))) 'tensor/backend-unsupported) true) (if (ref vulkan-backend 'float64) (= (handle (ml/clip-gradients (Dictionary 'w (to-device (Tensor Float64 [1] [1]) 'vulkan)) 1.0) (raise msg (ref msg 'code))) 'tensor/backend-unsupported) true)))", pass, fail);
    test_truthy(interp, "ml/optimizer-step Vulkan Float32 applies clip-norm before step",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (if (and (ref vulkan-backend 'ml-clip-gradients-float32) (ref vulkan-backend 'ml-optimizer-sgd-float32)) (let (r (ml/optimizer-step (Dictionary 'kind 'sgd 'learning-rate 1.0 'clip-norm 1.0) (Dictionary 'w (to-device (Tensor Float32 [2] [10 10]) 'vulkan)) (Dictionary 'w (to-device (Tensor Float32 [2] [4 3]) 'vulkan)) (Dictionary)) p (to-device (ref (ref r 'parameters) 'w) 'cpu)) (and (= (device (ref (ref r 'parameters) 'w)) 'vulkan) (< (abs (- (ref p [0]) (Float32 9.2))) (Float32 0.000001)) (< (abs (- (ref p [1]) (Float32 9.4))) (Float32 0.000001)))) true))", pass, fail);
    test_truthy(interp, "ml/save-optimizer and ml/load-optimizer round trip Adam state",
        "(let (step (ml/optimizer-step (Dictionary 'kind 'adam 'learning-rate 0.1) (Dictionary 'w (Tensor Float64 [1] [1])) (Dictionary 'w (Tensor Float64 [1] [0.1])) (Dictionary)) bundle (ml/load-optimizer (ml/save-optimizer (Dictionary 'kind 'adam 'learning-rate 0.1) (ref step 'state))) st (ref bundle 'state)) (and (= (ref bundle 'kind) 'optimizer) (= (ref (ref bundle 'spec) 'kind) 'adam) (= (ref st 'step) 1) (< (abs (- (ref (ref (ref st 'first-moment) 'w) [0]) 0.01)) 0.000000001)))", pass, fail);
    test_truthy(interp, "ml/save-optimizer and ml/load-optimizer support checkpoint path",
        "(let (path \"/tmp/omni-optimizer-checkpoint-test.json\" state (Dictionary 'velocity (Dictionary 'w (Tensor Float32 [1] [0.5]))) saved (ml/save-optimizer (Dictionary 'kind 'sgd 'learning-rate 0.1 'momentum 0.9) state path) bundle (ml/load-optimizer path) cleanup (fs-unlink path)) (and (= (ref (ref bundle 'spec) 'kind) 'sgd) (= (ref (ref (ref (ref bundle 'state) 'velocity) 'w) [0]) (Float32 0.5))))", pass, fail);
    test_truthy(interp, "ml/load-optimizer rejects wrong payload and invalid spec",
        "(and (= (handle (ml/load-optimizer (nn/save-spec (nn/dense 1 1))) (raise msg (ref msg 'code))) 'nn/invalid-spec) (= (handle (ml/save-optimizer (Dictionary 'kind 'adam 'learning-rate 0.1 'beta1 1.0) (Dictionary)) (raise msg (ref msg 'code))) 'tensor/invalid-argument))", pass, fail);
    test_truthy(interp, "tensor-backends exposes narrow optimizer capabilities",
        "(let (cpu-backend (ref (tensor-backends) 0) cuda-backend (ref (tensor-backends) 1) vulkan-backend (ref (tensor-backends) 3)) (and (ref cpu-backend 'ml-optimizer-sgd-float64) (ref cpu-backend 'ml-optimizer-sgd-float32) (ref cpu-backend 'ml-optimizer-adam-float64) (ref cpu-backend 'ml-optimizer-adam-float32) (ref cpu-backend 'ml-optimizer-adamw-float64) (ref cpu-backend 'ml-optimizer-adamw-float32) (ref cpu-backend 'ml-optimizer-rmsprop-float64) (ref cpu-backend 'ml-optimizer-rmsprop-float32) (ref cpu-backend 'ml-clip-gradients-float32) (= (ref cuda-backend 'ml-optimizer-sgd-float32) (ref cuda-backend 'elementwise-map-float32)) (= (ref cuda-backend 'ml-optimizer-adam-float32) (ref cuda-backend 'elementwise-map-float32)) (= (ref cuda-backend 'ml-optimizer-adamw-float32) (ref cuda-backend 'elementwise-map-float32)) (= (ref cuda-backend 'ml-optimizer-rmsprop-float32) (ref cuda-backend 'elementwise-map-float32)) (= (ref cuda-backend 'ml-optimizer) false) (= (ref vulkan-backend 'ml-optimizer-sgd-float32) (ref vulkan-backend 'float32)) (= (ref vulkan-backend 'ml-optimizer-adam-float32) (ref vulkan-backend 'float32)) (= (ref vulkan-backend 'ml-optimizer-adamw-float32) (ref vulkan-backend 'float32)) (= (ref vulkan-backend 'ml-optimizer-rmsprop-float32) (ref vulkan-backend 'float32)) (= (ref vulkan-backend 'ml-clip-gradients-float32) (ref vulkan-backend 'float32)) (= (ref vulkan-backend 'ml-optimizer) false)))", pass, fail);
    test_truthy(interp, "ml/optimizer-step SGD CUDA Float32 stateless update stays on device",
        "(let (cuda-backend (ref (tensor-backends) 1)) (if (ref cuda-backend 'ml-optimizer-sgd-float32) (let (r (ml/optimizer-step (Dictionary 'kind 'sgd 'learning-rate 0.1) (Dictionary 'w (to-device (Tensor Float32 [2] [2 4]) 'cuda)) (Dictionary 'w (to-device (Tensor Float32 [2] [0.5 -1]) 'cuda)) (Dictionary)) p (ref (ref r 'parameters) 'w) cpu (to-device p 'cpu)) (and (= (device p) 'cuda) (= (length (ref r 'state)) 0) (< (abs (- (ref cpu [0]) (Float32 1.95))) (Float32 0.0001)) (< (abs (- (ref cpu [1]) (Float32 4.1))) (Float32 0.0001)))) true))", pass, fail);
    test_truthy(interp, "ml/optimizer-step SGD CUDA Float32 initializes momentum state",
        "(let (cuda-backend (ref (tensor-backends) 1)) (if (ref cuda-backend 'ml-optimizer-sgd-float32) (let (r (ml/optimizer-step (Dictionary 'kind 'sgd 'learning-rate 0.1 'momentum 0.9) (Dictionary 'w (to-device (Tensor Float32 [1] [1]) 'cuda)) (Dictionary 'w (to-device (Tensor Float32 [1] [0.5]) 'cuda)) (Dictionary)) p (ref (ref r 'parameters) 'w) v (ref (ref (ref r 'state) 'velocity) 'w) pcpu (to-device p 'cpu) vcpu (to-device v 'cpu)) (and (= (device p) 'cuda) (= (device v) 'cuda) (< (abs (- (ref pcpu [0]) (Float32 0.95))) (Float32 0.0001)) (< (abs (- (ref vcpu [0]) (Float32 0.5))) (Float32 0.0001)))) true))", pass, fail);
    test_truthy(interp, "ml/optimizer-step SGD CUDA Float32 consumes momentum state",
        "(let (cuda-backend (ref (tensor-backends) 1)) (if (ref cuda-backend 'ml-optimizer-sgd-float32) (let (state (Dictionary 'velocity (Dictionary 'w (to-device (Tensor Float32 [1] [0.5]) 'cuda))) r (ml/optimizer-step (Dictionary 'kind 'sgd 'learning-rate 0.1 'momentum 0.9) (Dictionary 'w (to-device (Tensor Float32 [1] [0.95]) 'cuda)) (Dictionary 'w (to-device (Tensor Float32 [1] [0.5]) 'cuda)) state) p (ref (ref r 'parameters) 'w) v (ref (ref (ref r 'state) 'velocity) 'w) pcpu (to-device p 'cpu) vcpu (to-device v 'cpu)) (and (= (device p) 'cuda) (= (device v) 'cuda) (< (abs (- (ref pcpu [0]) (Float32 0.855))) (Float32 0.0001)) (< (abs (- (ref vcpu [0]) (Float32 0.95))) (Float32 0.0001)))) true))", pass, fail);
    test_truthy(interp, "ml/optimizer-step SGD CUDA rejects mixed placement",
        "(let (cuda-backend (ref (tensor-backends) 1)) (if (ref cuda-backend 'ml-optimizer-sgd-float32) (= (handle (ml/optimizer-step (Dictionary 'kind 'sgd 'learning-rate 0.1) (Dictionary 'w (to-device (Tensor Float32 [1] [1]) 'cuda)) (Dictionary 'w (Tensor Float32 [1] [0.5])) (Dictionary)) (raise msg (ref msg 'code))) 'tensor/backend-unsupported) true))", pass, fail);
    test_truthy_interp(interp, "ml/optimizer-step Adam CUDA Float32 initializes moment state",
        "(let (cuda-backend (ref (tensor-backends) 1)) (if (ref cuda-backend 'ml-optimizer-adam-float32) (let (r (ml/optimizer-step (Dictionary 'kind 'adam 'learning-rate 0.1) (Dictionary 'w (to-device (Tensor Float32 [1] [1]) 'cuda)) (Dictionary 'w (to-device (Tensor Float32 [1] [0.1]) 'cuda)) (Dictionary)) st (ref r 'state) p (ref (ref r 'parameters) 'w) m (ref (ref st 'first-moment) 'w) v (ref (ref st 'second-moment) 'w) pcpu (to-device p 'cpu) mcpu (to-device m 'cpu) vcpu (to-device v 'cpu)) (and (= (ref r 'optimizer) 'adam) (= (ref st 'step) 1) (= (device p) 'cuda) (= (device m) 'cuda) (= (device v) 'cuda) (< (abs (- (ref pcpu [0]) (Float32 0.9000001))) (Float32 0.0001)) (< (abs (- (ref mcpu [0]) (Float32 0.01))) (Float32 0.0001)) (< (abs (- (ref vcpu [0]) (Float32 0.00001))) (Float32 0.0001)))) true))", pass, fail);
    test_truthy_interp(interp, "ml/optimizer-step Adam CUDA Float32 consumes moment state",
        "(let (cuda-backend (ref (tensor-backends) 1)) (if (ref cuda-backend 'ml-optimizer-adam-float32) (let (state (Dictionary 'first-moment (Dictionary 'w (to-device (Tensor Float32 [1] [0.01]) 'cuda)) 'second-moment (Dictionary 'w (to-device (Tensor Float32 [1] [0.00001]) 'cuda)) 'step 1) r (ml/optimizer-step (Dictionary 'kind 'adam 'learning-rate 0.1) (Dictionary 'w (to-device (Tensor Float32 [1] [0.9]) 'cuda)) (Dictionary 'w (to-device (Tensor Float32 [1] [0.1]) 'cuda)) state) st (ref r 'state) p (ref (ref r 'parameters) 'w) m (ref (ref st 'first-moment) 'w) pcpu (to-device p 'cpu) mcpu (to-device m 'cpu)) (and (= (ref st 'step) 2) (= (device p) 'cuda) (= (device m) 'cuda) (< (abs (- (ref pcpu [0]) (Float32 0.8))) (Float32 0.0002)) (< (abs (- (ref mcpu [0]) (Float32 0.019))) (Float32 0.0001)))) true))", pass, fail);
    test_truthy(interp, "ml/optimizer-step Adam CUDA rejects mixed placement",
        "(let (cuda-backend (ref (tensor-backends) 1)) (if (ref cuda-backend 'ml-optimizer-adam-float32) (= (handle (ml/optimizer-step (Dictionary 'kind 'adam 'learning-rate 0.1) (Dictionary 'w (to-device (Tensor Float32 [1] [1]) 'cuda)) (Dictionary 'w (Tensor Float32 [1] [0.1])) (Dictionary)) (raise msg (ref msg 'code))) 'tensor/backend-unsupported) true))", pass, fail);
    test_truthy_interp(interp, "ml/optimizer-step AdamW CUDA Float32 decouples weight decay",
        "(let (cuda-backend (ref (tensor-backends) 1)) (if (ref cuda-backend 'ml-optimizer-adamw-float32) (let (r (ml/optimizer-step (Dictionary 'kind 'adamw 'learning-rate 0.1 'weight-decay 0.1) (Dictionary 'w (to-device (Tensor Float32 [1] [1]) 'cuda)) (Dictionary 'w (to-device (Tensor Float32 [1] [0]) 'cuda)) (Dictionary)) st (ref r 'state) p (ref (ref r 'parameters) 'w) pcpu (to-device p 'cpu)) (and (= (ref r 'optimizer) 'adamw) (= (ref st 'step) 1) (= (device p) 'cuda) (< (abs (- (ref pcpu [0]) (Float32 0.99))) (Float32 0.0001)))) true))", pass, fail);
    test_truthy(interp, "ml/optimizer-step AdamW CUDA rejects mixed placement",
        "(let (cuda-backend (ref (tensor-backends) 1)) (if (ref cuda-backend 'ml-optimizer-adamw-float32) (= (handle (ml/optimizer-step (Dictionary 'kind 'adamw 'learning-rate 0.1 'weight-decay 0.1) (Dictionary 'w (to-device (Tensor Float32 [1] [1]) 'cuda)) (Dictionary 'w (Tensor Float32 [1] [0])) (Dictionary)) (raise msg (ref msg 'code))) 'tensor/backend-unsupported) true))", pass, fail);
    test_truthy_interp(interp, "ml/optimizer-step RMSProp CUDA Float32 initializes square average",
        "(let (cuda-backend (ref (tensor-backends) 1)) (if (ref cuda-backend 'ml-optimizer-rmsprop-float32) (let (r (ml/optimizer-step (Dictionary 'kind 'rmsprop 'learning-rate 0.1 'alpha 0.0) (Dictionary 'w (to-device (Tensor Float32 [1] [1]) 'cuda)) (Dictionary 'w (to-device (Tensor Float32 [1] [0.5]) 'cuda)) (Dictionary)) st (ref r 'state) p (ref (ref r 'parameters) 'w) s (ref (ref st 'square-average) 'w) pcpu (to-device p 'cpu) scpu (to-device s 'cpu)) (and (= (ref r 'optimizer) 'rmsprop) (= (ref st 'step) 1) (= (device p) 'cuda) (= (device s) 'cuda) (< (abs (- (ref pcpu [0]) (Float32 0.9))) (Float32 0.0001)) (< (abs (- (ref scpu [0]) (Float32 0.25))) (Float32 0.0001)))) true))", pass, fail);
    test_truthy_interp(interp, "ml/optimizer-step RMSProp CUDA Float32 consumes momentum state",
        "(let (cuda-backend (ref (tensor-backends) 1)) (if (ref cuda-backend 'ml-optimizer-rmsprop-float32) (let (r1 (ml/optimizer-step (Dictionary 'kind 'rmsprop 'learning-rate 0.1 'alpha 0.0 'momentum 0.9) (Dictionary 'w (to-device (Tensor Float32 [1] [1]) 'cuda)) (Dictionary 'w (to-device (Tensor Float32 [1] [0.5]) 'cuda)) (Dictionary)) r2 (ml/optimizer-step (Dictionary 'kind 'rmsprop 'learning-rate 0.1 'alpha 0.0 'momentum 0.9) (ref r1 'parameters) (Dictionary 'w (to-device (Tensor Float32 [1] [0.5]) 'cuda)) (ref r1 'state)) st2 (ref r2 'state) p2 (ref (ref r2 'parameters) 'w) v2 (ref (ref st2 'velocity) 'w) pcpu (to-device p2 'cpu) vcpu (to-device v2 'cpu)) (and (= (ref st2 'step) 2) (= (device p2) 'cuda) (= (device v2) 'cuda) (< (abs (- (ref pcpu [0]) (Float32 0.71))) (Float32 0.0001)) (< (abs (- (ref vcpu [0]) (Float32 0.19))) (Float32 0.0001)))) true))", pass, fail);
    test_truthy(interp, "ml/optimizer-step RMSProp CUDA rejects mixed placement",
        "(let (cuda-backend (ref (tensor-backends) 1)) (if (ref cuda-backend 'ml-optimizer-rmsprop-float32) (= (handle (ml/optimizer-step (Dictionary 'kind 'rmsprop 'learning-rate 0.1 'alpha 0.0 'momentum 0.9) (Dictionary 'w (to-device (Tensor Float32 [1] [1]) 'cuda)) (Dictionary 'w (Tensor Float32 [1] [0.5])) (Dictionary)) (raise msg (ref msg 'code))) 'tensor/backend-unsupported) true))", pass, fail);
    test_truthy(interp, "ml/optimizer-step SGD Vulkan Float32 stateless update stays on device",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (if (ref vulkan-backend 'ml-optimizer-sgd-float32) (let (r (ml/optimizer-step (Dictionary 'kind 'sgd 'learning-rate 0.1 'weight-decay 0.1) (Dictionary 'w (to-device (Tensor Float32 [2] [2 4]) 'vulkan)) (Dictionary 'w (to-device (Tensor Float32 [2] [0.5 -1]) 'vulkan)) (Dictionary)) p (ref (ref r 'parameters) 'w) cpu (to-device p 'cpu)) (and (= (device p) 'vulkan) (= (length (ref r 'state)) 0) (< (abs (- (ref cpu [0]) (Float32 1.93))) (Float32 0.0001)) (< (abs (- (ref cpu [1]) (Float32 4.06))) (Float32 0.0001)))) true))", pass, fail);
    test_truthy(interp, "ml/optimizer-step SGD Vulkan Float32 initializes momentum state",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (if (ref vulkan-backend 'ml-optimizer-sgd-float32) (let (r (ml/optimizer-step (Dictionary 'kind 'sgd 'learning-rate 0.1 'momentum 0.9) (Dictionary 'w (to-device (Tensor Float32 [1] [1]) 'vulkan)) (Dictionary 'w (to-device (Tensor Float32 [1] [0.5]) 'vulkan)) (Dictionary)) p (ref (ref r 'parameters) 'w) v (ref (ref (ref r 'state) 'velocity) 'w) pcpu (to-device p 'cpu) vcpu (to-device v 'cpu)) (and (= (device p) 'vulkan) (= (device v) 'vulkan) (< (abs (- (ref pcpu [0]) (Float32 0.95))) (Float32 0.0001)) (< (abs (- (ref vcpu [0]) (Float32 0.5))) (Float32 0.0001)))) true))", pass, fail);
    test_truthy(interp, "ml/optimizer-step SGD Vulkan Float32 consumes momentum state",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (if (ref vulkan-backend 'ml-optimizer-sgd-float32) (let (state (Dictionary 'velocity (Dictionary 'w (to-device (Tensor Float32 [1] [0.5]) 'vulkan))) r (ml/optimizer-step (Dictionary 'kind 'sgd 'learning-rate 0.1 'momentum 0.9) (Dictionary 'w (to-device (Tensor Float32 [1] [0.95]) 'vulkan)) (Dictionary 'w (to-device (Tensor Float32 [1] [0.5]) 'vulkan)) state) p (ref (ref r 'parameters) 'w) v (ref (ref (ref r 'state) 'velocity) 'w) pcpu (to-device p 'cpu) vcpu (to-device v 'cpu)) (and (= (device p) 'vulkan) (= (device v) 'vulkan) (< (abs (- (ref pcpu [0]) (Float32 0.855))) (Float32 0.0001)) (< (abs (- (ref vcpu [0]) (Float32 0.95))) (Float32 0.0001)))) true))", pass, fail);
    test_truthy(interp, "ml/optimizer-step SGD Vulkan rejects mixed placement",
