    test_truthy(interp, "kernel/run executes checked Vulkan add-f32 kernels",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (if (ref vulkan-backend 'float32) (let (k (Kernel (Dictionary 'backend 'vulkan 'operation 'add-f32 'inputs (Array (Dictionary 'name 'x 'dtype 'Float32 'shape (Array 'n)) (Dictionary 'name 'y 'dtype 'Float32 'shape (Array 'n))) 'outputs (Array (Dictionary 'name 'z 'dtype 'Float32 'shape (Array 'n))))) r (kernel/run k (Dictionary 'x (to-device (Tensor Float32 [2] [3 4]) 'vulkan) 'y (to-device (Tensor Float32 [2] [0.5 1.25]) 'vulkan)) (Dictionary)) z (to-device (ref r 'z) 'cpu)) (and (= (device (ref r 'z)) 'vulkan) (< (abs (- (ref z [0]) (Float32 3.5))) (Float32 0.000001)) (< (abs (- (ref z [1]) (Float32 5.25))) (Float32 0.000001)))) true))", pass, fail);
    test_truthy(interp, "kernel/run executes checked Vulkan binary Float32 kernels",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (if (ref vulkan-backend 'float32) (let (ins (Array (Dictionary 'name 'x 'dtype 'Float32 'shape (Array 'n)) (Dictionary 'name 'y 'dtype 'Float32 'shape (Array 'n))) outs (Array (Dictionary 'name 'z 'dtype 'Float32 'shape (Array 'n))) x (to-device (Tensor Float32 [2] [6 8]) 'vulkan) y (to-device (Tensor Float32 [2] [3 4]) 'vulkan) ksub (Kernel (Dictionary 'backend 'vulkan 'operation 'sub-f32 'inputs ins 'outputs outs)) kmul (Kernel (Dictionary 'backend 'vulkan 'operation 'mul-f32 'inputs ins 'outputs outs)) kdiv (Kernel (Dictionary 'backend 'vulkan 'operation 'div-f32 'inputs ins 'outputs outs)) kmin (Kernel (Dictionary 'backend 'vulkan 'operation 'min-f32 'inputs ins 'outputs outs)) kmax (Kernel (Dictionary 'backend 'vulkan 'operation 'max-f32 'inputs ins 'outputs outs)) rsub (kernel/run ksub (Dictionary 'x x 'y y) (Dictionary)) rmul (kernel/run kmul (Dictionary 'x x 'y y) (Dictionary)) rdiv (kernel/run kdiv (Dictionary 'x x 'y y) (Dictionary)) rmin (kernel/run kmin (Dictionary 'x x 'y y) (Dictionary)) rmax (kernel/run kmax (Dictionary 'x x 'y y) (Dictionary)) sub (to-device (ref rsub 'z) 'cpu) mul (to-device (ref rmul 'z) 'cpu) div (to-device (ref rdiv 'z) 'cpu) mn (to-device (ref rmin 'z) 'cpu) mx (to-device (ref rmax 'z) 'cpu)) (and (= (device (ref rsub 'z)) 'vulkan) (= (device (ref rmax 'z)) 'vulkan) (< (abs (- (ref sub [0]) (Float32 3.0))) (Float32 0.000001)) (< (abs (- (ref sub [1]) (Float32 4.0))) (Float32 0.000001)) (< (abs (- (ref mul [0]) (Float32 18.0))) (Float32 0.000001)) (< (abs (- (ref mul [1]) (Float32 32.0))) (Float32 0.000001)) (< (abs (- (ref div [0]) (Float32 2.0))) (Float32 0.000001)) (< (abs (- (ref div [1]) (Float32 2.0))) (Float32 0.000001)) (< (abs (- (ref mn [0]) (Float32 3.0))) (Float32 0.000001)) (< (abs (- (ref mn [1]) (Float32 4.0))) (Float32 0.000001)) (< (abs (- (ref mx [0]) (Float32 6.0))) (Float32 0.000001)) (< (abs (- (ref mx [1]) (Float32 8.0))) (Float32 0.000001)))) true))", pass, fail);
    test_truthy(interp, "kernel/run executes checked Vulkan scalar Float32 kernels",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (if (ref vulkan-backend 'float32) (let (ins (Array (Dictionary 'name 'x 'dtype 'Float32 'shape (Array 'n))) outs (Array (Dictionary 'name 'z 'dtype 'Float32 'shape (Array 'n))) x (to-device (Tensor Float32 [2] [8 4]) 'vulkan) kadd (Kernel (Dictionary 'backend 'vulkan 'operation 'add-scalar-f32 'inputs ins 'outputs outs 'push (Dictionary 'scalar 'Float32))) ksub (Kernel (Dictionary 'backend 'vulkan 'operation 'sub-scalar-f32 'inputs ins 'outputs outs 'push (Dictionary 'scalar 'Float32))) kleft (Kernel (Dictionary 'backend 'vulkan 'operation 'scalar-sub-f32 'inputs ins 'outputs outs 'push (Dictionary 'scalar 'Float32))) kdiv (Kernel (Dictionary 'backend 'vulkan 'operation 'div-scalar-f32 'inputs ins 'outputs outs 'push (Dictionary 'scalar 'Float32))) kldiv (Kernel (Dictionary 'backend 'vulkan 'operation 'scalar-div-f32 'inputs ins 'outputs outs 'push (Dictionary 'scalar 'Float32))) radd (kernel/run kadd (Dictionary 'x x) (Dictionary 'scalar (Float32 2.0))) rsub (kernel/run ksub (Dictionary 'x x) (Dictionary 'scalar (Float32 2.0))) rleft (kernel/run kleft (Dictionary 'x x) (Dictionary 'scalar (Float32 2.0))) rdiv (kernel/run kdiv (Dictionary 'x x) (Dictionary 'scalar (Float32 2.0))) rldiv (kernel/run kldiv (Dictionary 'x x) (Dictionary 'scalar (Float32 2.0))) add (to-device (ref radd 'z) 'cpu) sub (to-device (ref rsub 'z) 'cpu) left (to-device (ref rleft 'z) 'cpu) div (to-device (ref rdiv 'z) 'cpu) ldiv (to-device (ref rldiv 'z) 'cpu)) (and (= (device (ref radd 'z)) 'vulkan) (= (device (ref rldiv 'z)) 'vulkan) (< (abs (- (ref add [0]) (Float32 10.0))) (Float32 0.000001)) (< (abs (- (ref sub [1]) (Float32 2.0))) (Float32 0.000001)) (< (abs (- (ref left [0]) (Float32 -6.0))) (Float32 0.000001)) (< (abs (- (ref div [0]) (Float32 4.0))) (Float32 0.000001)) (< (abs (- (ref ldiv [1]) (Float32 0.5))) (Float32 0.000001)))) true))", pass, fail);
    test_truthy(interp, "kernel/run executes checked Vulkan unary Float32 kernels",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (if (ref vulkan-backend 'float32) (let (ins (Array (Dictionary 'name 'x 'dtype 'Float32 'shape (Array 'n))) outs (Array (Dictionary 'name 'z 'dtype 'Float32 'shape (Array 'n))) x (to-device (Tensor Float32 [2] [4 1]) 'vulkan) zero (to-device (Tensor Float32 [1] [0]) 'vulkan) ksqrt (Kernel (Dictionary 'backend 'vulkan 'operation 'sqrt-f32 'inputs ins 'outputs outs)) kneg (Kernel (Dictionary 'backend 'vulkan 'operation 'neg-f32 'inputs ins 'outputs outs)) kzero (Kernel (Dictionary 'backend 'vulkan 'operation 'zero-f32 'inputs ins 'outputs outs)) kncdf (Kernel (Dictionary 'backend 'vulkan 'operation 'normal-cdf-f32 'inputs ins 'outputs outs)) rsqrt (kernel/run ksqrt (Dictionary 'x x) (Dictionary)) rneg (kernel/run kneg (Dictionary 'x x) (Dictionary)) rzero (kernel/run kzero (Dictionary 'x x) (Dictionary)) rcdf (kernel/run kncdf (Dictionary 'x zero) (Dictionary)) sqrt (to-device (ref rsqrt 'z) 'cpu) neg (to-device (ref rneg 'z) 'cpu) zeros (to-device (ref rzero 'z) 'cpu) cdf (to-device (ref rcdf 'z) 'cpu)) (and (= (device (ref rsqrt 'z)) 'vulkan) (= (device (ref rcdf 'z)) 'vulkan) (< (abs (- (ref sqrt [0]) (Float32 2.0))) (Float32 0.000001)) (< (abs (- (ref sqrt [1]) (Float32 1.0))) (Float32 0.000001)) (< (abs (- (ref neg [0]) (Float32 -4.0))) (Float32 0.000001)) (< (abs (- (ref zeros [1]) (Float32 0.0))) (Float32 0.000001)) (< (abs (- (ref cdf [0]) (Float32 0.5))) (Float32 0.000001)))) true))", pass, fail);
    test_truthy(interp, "kernel/run scalar Float32 validates push contract",
        "(let (k (Kernel (Dictionary 'backend 'vulkan 'operation 'add-scalar-f32 'inputs (Array (Dictionary 'name 'x 'dtype 'Float32 'shape (Array 'n))) 'outputs (Array (Dictionary 'name 'z 'dtype 'Float32 'shape (Array 'n))) 'push (Dictionary 'scalar 'Float32)))) (and (= (handle (kernel/run k (Dictionary 'x (Tensor Float32 [1] [1])) (Dictionary)) (raise msg (ref msg 'code))) 'tensor/invalid-argument) (= (handle (kernel/run k (Dictionary 'x (Tensor Float32 [1] [1])) (Dictionary 'scalar (Float32 1.0) 'extra (Float32 2.0))) (raise msg (ref msg 'code))) 'tensor/invalid-argument)))", pass, fail);
    test_truthy(interp, "kernel/run unary Float32 validates placement and push contract",
