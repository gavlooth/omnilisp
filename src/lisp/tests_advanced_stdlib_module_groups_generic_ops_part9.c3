module lisp;

import std::io;
import main;

const usz ML_VALIDATION_BENCH_INFERENCE_ITERS = 128;
const usz ML_VALIDATION_BENCH_TRAIN_ITERS = 64;

fn bool ml_validation_bench_enabled() @inline {
    return test_c_getenv("OMNI_ML_BENCH") != null;
}

fn long ml_validation_bench_now_ms() @inline {
    long now_ms = scheduler_monotonic_ms();
    if (now_ms > 0) return now_ms;
    return 0;
}

fn long ml_validation_bench_ok_count(EvalResult result) @inline {
    if (result.error.has_error || result.value == null || !is_int(result.value)) return -1;
    return result.value.int_val;
}

fn void run_ml_validation_benchmarks(Interp* interp) {
    if (!ml_validation_bench_enabled()) return;
    if (interp == null) return;

    emit_test_section_banner("ML Validation Benchmarks");

    usz recycle_before = main::g_scope_memory_telemetry_stats.scope_recycle_count;
    CopyToParentStats copy_before = copy_to_parent_stats_snapshot();

    long inference_start_ms = ml_validation_bench_now_ms();
    EvalResult inference_result = run(
        "(let loop (i 0 ok 0) "
        "  (if (= i 128) ok "
        "      (let (out (ml/linear (Tensor Float32 [2 2] [1 2 3 4]) "
        "                            (Tensor Float32 [2 2] [1 0 0 1]) "
        "                            (Tensor Float32 [2] [0.5 -0.5]))) "
        "        (loop (+ i 1) (+ ok 1)))))",
        interp
    );
    long inference_done_ms = ml_validation_bench_now_ms();

    EvalResult training_result = run(
        "(let loop (i 0 params (Dictionary 'w (Tensor Float32 [2] [1 2])) state (Dictionary) ok 0) "
        "  (if (= i 64) ok "
        "      (let (r (ml/optimizer-step (Dictionary 'kind 'sgd 'learning-rate 0.01 'momentum 0.9) "
        "                                  params "
        "                                  (Dictionary 'w (Tensor Float32 [2] [0.5 -0.25])) "
        "                                  state)) "
        "        (loop (+ i 1) (ref r 'parameters) (ref r 'state) (+ ok 1)))))",
        interp
    );
    long training_done_ms = ml_validation_bench_now_ms();

    usz recycle_after = main::g_scope_memory_telemetry_stats.scope_recycle_count;
    CopyToParentStats copy_after = copy_to_parent_stats_snapshot();

    long inference_ok = ml_validation_bench_ok_count(inference_result);
    long training_ok = ml_validation_bench_ok_count(training_result);
    long inference_ms = inference_done_ms > inference_start_ms ? inference_done_ms - inference_start_ms : 0;
    long training_ms = training_done_ms > inference_done_ms ? training_done_ms - inference_done_ms : 0;
    usz recycle_delta = recycle_after >= recycle_before ? recycle_after - recycle_before : 0;
    usz copy_total_delta = copy_after.total_calls >= copy_before.total_calls
        ? copy_after.total_calls - copy_before.total_calls
        : 0;
    usz copy_reuse_delta = copy_after.fast_reuse_hits >= copy_before.fast_reuse_hits
        ? copy_after.fast_reuse_hits - copy_before.fast_reuse_hits
        : 0;

    io::printfn(
        "OMNI_BENCH_SUMMARY suite=ml_inference_oracle iters=%d inference_ms=%d inference_ok=%d",
        (long)ML_VALIDATION_BENCH_INFERENCE_ITERS,
        inference_ms,
        inference_ok
    );
    io::printfn(
        "OMNI_BENCH_SUMMARY suite=ml_training_step_oracle iters=%d train_ms=%d train_ok=%d scope_recycle_delta=%d copy_total_delta=%d copy_reuse_delta=%d",
        (long)ML_VALIDATION_BENCH_TRAIN_ITERS,
        training_ms,
        training_ok,
        (long)recycle_delta,
        (long)copy_total_delta,
        (long)copy_reuse_delta
    );
}

fn void run_advanced_collections_generic_ops_part9(Interp* interp, int* pass, int* fail) {
    test_truthy(interp, "ml/plot returns FTXUI graph node for scalar array series",
        "(let (plot (ml/plot [1 2 3]) props (ref plot 'props) series (ref props 'series)) (and (= (ref plot 'kind) 'graph) (= (ref props 'visualization) 'ml/plot) (= (ref props 'backend) 'ftxui) (= (ref props 'title) \"ML Plot\") (= (length series) 3) (= (ref series 0) 1.0) (= (ref series 2) 3.0) (= (ref plot 'children) nil)))", pass, fail);
    test_truthy(interp, "ml/plot preserves x/y metadata while exposing graph y series",
        "(let (plot (ml/plot [[0 1] [2 5]]) props (ref plot 'props) x (ref props 'x) y (ref props 'series)) (and (= (length x) 2) (= (length y) 2) (= (ref x 1) 2.0) (= (ref y 1) 5.0)))", pass, fail);
    test_truthy(interp, "ml/plot accepts Float32 rank-1 CPU Tensor series",
        "(let (plot (ml/plot (Tensor Float32 [3] [1 2 3])) series (ref (ref plot 'props) 'series)) (and (= (length series) 3) (= (ref series 0) 1.0) (= (ref series 2) 3.0)))", pass, fail);
    test_truthy(interp, "ml/loss-curve returns titled FTXUI graph node",
        "(let (plot (ml/loss-curve [1.0 0.5 0.25] (Dictionary 'title \"train loss\" 'width 40 'height 8)) props (ref plot 'props) series (ref props 'series)) (and (= (ref plot 'kind) 'graph) (= (ref props 'visualization) 'ml/loss-curve) (= (ref props 'title) \"train loss\") (= (ref props 'width) 40) (= (ref props 'height) 8) (= (length series) 3) (= (ref series 2) 0.25)))", pass, fail);
    test_truthy(interp, "ml/plot supports multi-series overlays as graph-compatible data",
        "(let (plot (ml/plot [[1 2 3] [3 2 1]] (Dictionary 'legend [\"up\" \"down\"])) props (ref plot 'props) all (ref props 'series-list) first (ref all 0) second (ref all 1)) (and (= (ref plot 'kind) 'graph) (= (ref props 'plot-kind) 'multi-series) (= (length all) 2) (= (ref first 2) 3.0) (= (ref second 0) 3.0) (= (ref (ref props 'legend) 1) \"down\")))", pass, fail);
    test_truthy(interp, "ml/plot applies x data-window zoom to graph series",
        "(let (plot (ml/plot [10 20 30 40] (Dictionary 'zoom (Dictionary 'x-min 1 'x-max 2 'y-min 0))) props (ref plot 'props) series (ref props 'series) zoom (ref props 'zoom)) (and (= (ref props 'plot-kind) 'line) (= (length series) 2) (= (ref series 0) 20.0) (= (ref series 1) 30.0) (= (ref zoom 'mode) 'data-window) (= (ref zoom 'interactive) false) (= (ref zoom 'x-min) 1.0)))", pass, fail);
    test_truthy(interp, "ml/scatter preserves x/y points and marker metadata",
        "(let (plot (ml/scatter [[0 1] [2 5]] (Dictionary 'marker 'cross)) props (ref plot 'props) points (ref props 'points) point (ref points 1)) (and (= (ref plot 'kind) 'graph) (= (ref props 'plot-kind) 'scatter) (= (ref props 'marker) 'cross) (= (ref point 0) 2.0) (= (ref point 1) 5.0)))", pass, fail);
    test_truthy(interp, "ml/bar-chart and ml/histogram return typed graph data",
        "(let (bar (ml/bar-chart [2 4] (Dictionary 'labels [\"a\" \"b\"])) bp (ref bar 'props) hist (ml/histogram [0 0.5 1.0] (Dictionary 'bins 2)) hp (ref hist 'props) counts (ref hp 'series) edges (ref hp 'bin-edges)) (and (= (ref bp 'plot-kind) 'bar-chart) (= (ref (ref bp 'labels) 0) \"a\") (= (ref hp 'plot-kind) 'histogram) (= (ref hp 'sample-count) 3) (= (length counts) 2) (= (ref counts 0) 1.0) (= (ref counts 1) 2.0) (= (length edges) 3)))", pass, fail);
    test_truthy(interp, "ml/heatmap and named ROC/PR curves return declarative ML plot data",
        "(let (heat (ml/heatmap [[1 2] [3 4]]) roc (ml/roc-curve [[0.0 0.0] [1.0 1.0]]) pr (ml/pr-curve [[0.0 1.0] [1.0 0.5]])) (and (= (ref heat 'kind) 'heatmap) (= (ref heat 'width) 2) (= (ref heat 'height) 2) (= (ref heat 'min) 1.0) (= (ref heat 'max) 4.0) (= (ref (ref roc 'props) 'plot-kind) 'roc-curve) (= (ref (ref roc 'props) 'x-label) 'false-positive-rate) (= (ref (ref pr 'props) 'plot-kind) 'pr-curve) (= (ref (ref pr 'props) 'y-label) 'precision)))", pass, fail);
    test_truthy(interp, "ML visualization diagnostics fail closed",
        "(and (= (handle (ml/plot []) (raise msg (ref msg 'code))) 'ml/invalid-visualization) (= (handle (ml/loss-curve [[0 1]]) (raise msg (ref msg 'code))) 'ml/invalid-visualization) (= (handle (ml/plot [1 2] (Dictionary 'backend 'image)) (raise msg (ref msg 'code))) 'ml/backend-unsupported) (= (handle (ml/plot (Tensor BigInteger [2] [1 2])) (raise msg (ref msg 'code))) 'tensor/backend-unsupported) (= (handle (ml/scatter [1 2]) (raise msg (ref msg 'code))) 'ml/invalid-visualization) (= (handle (ml/histogram [1 2] (Dictionary 'bins 0)) (raise msg (ref msg 'code))) 'ml/invalid-visualization) (= (handle (ml/heatmap [[1] [2 3]]) (raise msg (ref msg 'code))) 'ml/invalid-visualization) (= (handle (ml/plot [1 2] (Dictionary 'zoom (Dictionary 'x-min 3 'x-max 1))) (raise msg (ref msg 'code))) 'ml/invalid-visualization))", pass, fail);
    test_truthy(interp, "ml/tensor-summary reports CPU real tensor metadata and stats",
        "(let (summary (ml/tensor-summary (Tensor Float64 [2 2] [1 2 3 4]) (Dictionary 'title \"weights\")) stats (ref summary 'stats)) (and (= (ref summary 'kind) 'tensor-summary) (= (ref summary 'dtype) 'Float64) (= (ref summary 'device) 'cpu) (= (ref summary 'payload) 'concrete) (= (ref summary 'layout) 'dense-row-major) (= (ref summary 'title) \"weights\") (= (ref (ref summary 'shape) 0) 2) (= (ref (ref summary 'shape) 1) 2) (= (ref summary 'element-count) 4) (= (ref stats 'status) 'available) (= (ref stats 'finite) true) (= (ref stats 'min) 1.0) (= (ref stats 'max) 4.0) (= (ref stats 'mean) 2.5)))", pass, fail);
    test_truthy(interp, "ml/tensor-summary accepts unsupported stat surfaces without fallback",
        "(let (big (ml/tensor-summary (Tensor BigInteger [2] [1 2])) vulkan-backend (ref (tensor-backends) 3)) (and (= (ref (ref big 'stats) 'status) 'unavailable) (= (ref (ref big 'stats) 'reason) 'unsupported-dtype) (if (ref vulkan-backend 'float32) (let (gpu (ml/tensor-summary (to-device (Tensor Float32 [2] [1 2]) 'vulkan))) (and (= (ref gpu 'device) 'vulkan) (= (ref (ref gpu 'stats) 'status) 'unavailable) (= (ref (ref gpu 'stats) 'reason) 'non-cpu-device))) true)))", pass, fail);
    test_truthy(interp, "ml/confusion-matrix returns target-row predicted-column counts",
        "(let (cm (ml/confusion-matrix [0 1 1 2 2] [0 1 2 2 1] (Dictionary 'title \"classes\")) m (ref cm 'matrix)) (and (= (ref cm 'kind) 'confusion-matrix) (= (ref cm 'title) \"classes\") (= (ref cm 'orientation) 'target-rows-predicted-columns) (= (length (ref cm 'labels)) 3) (= (ref cm 'total) 5) (= (ref cm 'correct) 3) (< (abs (- (ref cm 'accuracy) 0.6)) 0.000000001) (= (ref (ref m 0) 0) 1) (= (ref (ref m 1) 1) 1) (= (ref (ref m 1) 2) 1) (= (ref (ref m 2) 1) 1) (= (ref (ref m 2) 2) 1)))", pass, fail);
    test_truthy(interp, "ml/confusion-matrix accepts Float32 rank-1 CPU tensors",
        "(let (cm (ml/confusion-matrix (Tensor Float32 [4] [0 1 1 0]) (Tensor Float32 [4] [0 1 0 0])) m (ref cm 'matrix)) (and (= (ref cm 'total) 4) (= (ref cm 'correct) 3) (= (ref (ref m 0) 0) 2) (= (ref (ref m 0) 1) 1) (= (ref (ref m 1) 1) 1)))", pass, fail);
    test_truthy(interp, "ml/confusion-matrix diagnostics fail closed",
        "(and (= (handle (ml/confusion-matrix [0 1] [0]) (raise msg (ref msg 'code))) 'ml/invalid-visualization) (= (handle (ml/confusion-matrix [0.5] [0]) (raise msg (ref msg 'code))) 'ml/invalid-visualization) (= (handle (ml/confusion-matrix [0] [0] (Dictionary 'backend 'image)) (raise msg (ref msg 'code))) 'ml/backend-unsupported) (= (handle (ml/confusion-matrix (Tensor BigInteger [1] [0]) (Tensor BigInteger [1] [0])) (raise msg (ref msg 'code))) 'tensor/backend-unsupported))", pass, fail);
    test_truthy(interp, "ml/export-image writes grayscale PPM metadata",
        "(let (out (ml/export-image (Tensor Float32 [2 2] [0.0 0.5 1.0 0.25]) \"/tmp/omni_ml_export_gray.ppm\")) (and (= (ref out 'kind) 'image-export) (= (ref out 'format) 'ppm) (= (ref out 'backend) 'ppm) (= (ref out 'range) 'unit) (= (ref out 'width) 2) (= (ref out 'height) 2) (= (ref out 'channels) 1)))", pass, fail);
    test_truthy(interp, "ml/export-image writes RGB PPM byte range metadata",
        "(let (out (ml/export-image (Tensor Float64 [1 2 3] [255 0 0 0 128 255]) \"/tmp/omni_ml_export_rgb.ppm\" (Dictionary 'range 'byte 'format 'ppm 'backend 'image))) (and (= (ref out 'kind) 'image-export) (= (ref out 'range) 'byte) (= (ref out 'width) 2) (= (ref out 'height) 1) (= (ref out 'channels) 3)))", pass, fail);
    test_truthy(interp, "ml/export-image diagnostics fail closed",
        "(and (= (handle (ml/export-image [1 2] \"/tmp/not_tensor.ppm\") (raise msg (ref msg 'code))) 'type/arg-mismatch) (= (handle (ml/export-image (Tensor Float32 [1 1 2] [0 1]) \"/tmp/bad_channels.ppm\") (raise msg (ref msg 'code))) 'ml/invalid-visualization) (= (handle (ml/export-image (Tensor Float32 [1 1] [2.0]) \"/tmp/bad_unit.ppm\" (Dictionary 'range 'unit)) (raise msg (ref msg 'code))) 'ml/invalid-visualization) (= (handle (ml/export-image (Tensor BigInteger [1 1] [1]) \"/tmp/bad_dtype.ppm\") (raise msg (ref msg 'code))) 'tensor/backend-unsupported) (= (handle (ml/export-image (Tensor Float32 [1 1] [0]) \"/tmp/bad_format.ppm\" (Dictionary 'format 'png)) (raise msg (ref msg 'code))) 'ml/backend-unsupported))", pass, fail);
    test_truthy(interp, "nn/forward runs train-mode dense model without hidden state mutation",
        "(let (model (nn/init (nn/dense 2 1 (Dictionary 'kernel-init (Dictionary 'kind 'ones) 'bias-init (Dictionary 'kind 'zeros))) (Dictionary 'dtype 'Float32 'device 'cpu 'mode 'train 'seed 1)) out (nn/forward model (Tensor Float32 [2] [1 2]))) (and (= (ref out [0]) (Float32 3.0)) (= (nn/mode model) 'train)))", pass, fail);
    test_truthy(interp, "nn/batch-normalization initializes explicit affine params and running state",
        "(let (model (nn/init (nn/batch-normalization 2 1) (Dictionary 'dtype 'Float64 'device 'cpu 'mode 'eval 'seed 1)) params (nn/parameters model) state (nn/state model)) (and (= (ref (nn/spec model) 'kind) 'batch-normalization) (= (ref (ref params 'scale) [0]) 1.0) (= (ref (ref params 'bias) [1]) 0.0) (= (ref (ref state 'running-mean) [0]) 0.0) (= (ref (ref state 'running-variance) [1]) 1.0)))", pass, fail);
    test_truthy(interp, "nn/forward batch-normalization returns updated model state without mutating original",
        "(let (model (nn/init (nn/batch-normalization 2 1 (Dictionary 'epsilon 1.0 'momentum 1.0)) (Dictionary 'dtype 'Float64 'device 'cpu 'mode 'train 'seed 1)) res (nn/forward model (Tensor Float64 [2 2] [1 2 3 6])) out (ref res 'output) next (ref res 'model) st (nn/state next) orig (nn/state model)) (and (= (ref res 'kind) 'nn-forward) (< (abs (+ (ref out [0 0]) 0.7071067811865475)) 0.000000001) (< (abs (- (ref out [1 1]) 0.8944271909999159)) 0.000000001) (= (ref (ref st 'running-mean) [0]) 2.0) (= (ref (ref st 'running-mean) [1]) 4.0) (= (ref (ref st 'running-variance) [0]) 1.0) (= (ref (ref st 'running-variance) [1]) 4.0) (= (ref (ref orig 'running-mean) [0]) 0.0)))", pass, fail);
    test_truthy(interp, "nn/forward explicit batch-normalization train mode threads state through sequential specs",
        "(let (spec (nn/sequential (nn/batch-normalization 2 1 (Dictionary 'epsilon 1.0 'momentum 1.0))) model (nn/init spec (Dictionary 'dtype 'Float64 'device 'cpu 'mode 'eval 'seed 1)) res (nn/forward (nn/spec model) (nn/parameters model) (nn/state model) (Tensor Float64 [2 2] [1 2 3 6]) (Dictionary 'mode 'train)) st (ref res 'state) layer-state (ref st 0)) (and (= (ref res 'kind) 'nn-forward) (= (ref (ref layer-state 'running-mean) [0]) 2.0) (= (ref (ref layer-state 'running-variance) [1]) 4.0)))", pass, fail);
    test_truthy(interp, "nn/batch-normalization rejects invalid options and train-mode device fallback",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (and (= (handle (nn/batch-normalization 2 1 (Dictionary 'momentum 1.1)) (raise msg (ref msg 'code))) 'nn/invalid-spec) (if (ref vulkan-backend 'float32) (= (handle (nn/forward (nn/init (nn/batch-normalization 1 0) (Dictionary 'dtype 'Float32 'device 'vulkan 'mode 'train)) (to-device (Tensor Float32 [1] [1]) 'vulkan)) (raise msg (ref msg 'code))) 'tensor/backend-unsupported) true)))", pass, fail);
    test_truthy(interp, "nn/forward batch-normalization rejects Vulkan running-state placement",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (if (ref vulkan-backend 'float32) (= (handle (nn/forward (nn/batch-normalization 1 0) (Dictionary 'scale (Tensor Float32 [1] [1]) 'bias (Tensor Float32 [1] [0])) (Dictionary 'running-mean (to-device (Tensor Float32 [1] [0]) 'vulkan) 'running-variance (to-device (Tensor Float32 [1] [1]) 'vulkan)) (Tensor Float32 [1] [1]) (Dictionary 'mode 'train)) (raise msg (ref msg 'code))) 'tensor/backend-unsupported) true))", pass, fail);
    test_truthy(interp, "nn/forward batch-normalization rejects Vulkan affine placement before state update",
        "(let (vulkan-backend (ref (tensor-backends) 3)) (if (ref vulkan-backend 'float32) (= (handle (nn/forward (nn/batch-normalization 1 0) (Dictionary 'scale (to-device (Tensor Float32 [1] [1]) 'vulkan) 'bias (to-device (Tensor Float32 [1] [0]) 'vulkan)) (Dictionary 'running-mean (Tensor Float32 [1] [0]) 'running-variance (Tensor Float32 [1] [1])) (Tensor Float32 [1] [1]) (Dictionary 'mode 'train)) (raise msg (ref msg 'code))) 'tensor/backend-unsupported) true))", pass, fail);
    test_truthy(interp, "nn/grad lifts dense activation gradients into sequential parameter tree",
        "(let (model (nn/init (nn/sequential (nn/dense 2 1 (Dictionary 'kernel-init (Dictionary 'kind 'ones) 'bias-init (Dictionary 'kind 'zeros))) (nn/relu)) (Dictionary 'dtype 'Float64 'device 'cpu 'mode 'train 'seed 1)) g (nn/grad model (Tensor Float64 [2] [1 2]) (Tensor Float64 [1] [4])) tree (ref g 'parameter-gradients) dense (ref tree 0) act (ref tree 1)) (and (= (ref g 'kind) 'nn-gradients) (= (ref g 'loss-kind) 'mean-squared-error) (= (length act) 0) (= (ref (ref dense 'weights) [0 0]) -2.0) (= (ref (ref dense 'weights) [0 1]) -4.0) (= (ref (ref dense 'bias) [0]) -2.0)))", pass, fail);
    test_truthy(interp, "nn/grad defaults softmax output layer to cross entropy",
        "(let (model (nn/init (nn/dense 1 2 (Dictionary 'activation 'softmax 'kernel-init (Dictionary 'kind 'zeros) 'bias-init (Dictionary 'kind 'zeros))) (Dictionary 'dtype 'Float32 'device 'cpu 'mode 'train 'seed 1)) g (nn/grad model (Tensor Float32 [1] [1]) (Tensor Float32 [2] [1 0])) pg (ref g 'parameter-gradients)) (and (= (ref g 'source) 'linear-softmax-cross-entropy) (= (ref g 'loss-kind) 'softmax-cross-entropy) (< (abs (- (ref (ref g 'loss) []) (Float32 0.69314718))) (Float32 0.0001)) (= (ref (ref pg 'weights) [0 0]) (Float32 -0.5)) (= (ref (ref pg 'bias) [1]) (Float32 0.5))))", pass, fail);
    test_truthy(interp, "nn/train-step returns updated model and optimizer state data",
        "(let (model (nn/init (nn/dense 2 1 (Dictionary 'kernel-init (Dictionary 'kind 'ones) 'bias-init (Dictionary 'kind 'zeros))) (Dictionary 'dtype 'Float64 'device 'cpu 'mode 'train 'seed 1)) step (nn/train-step model (Tensor Float64 [2] [1 2]) (Tensor Float64 [1] [4]) (Dictionary 'kind 'sgd 'learning-rate 0.1 'momentum 0.9) (Dictionary)) next (ref step 'model) weights (ref (ref (nn/parameters next) 'weights) [0 0]) velocity (ref (ref (ref step 'optimizer-state) 'velocity) 'weights)) (and (= (ref step 'kind) 'train-step) (= (nn/mode next) 'train) (< (abs (- weights 1.2)) 0.000000001) (= (ref velocity [0 0]) -2.0) (= (ref (ref step 'loss) []) 1.0)))", pass, fail);
    test_truthy(interp, "nn optimizer constructors produce ordinary optimizer specs",
        "(let (sgd (nn/sgd 0.1 (Dictionary 'momentum 0.9 'clip-norm 1.0)) adam (nn/adam 0.001 (Dictionary 'beta1 0.8 'beta2 0.99 'epsilon 0.000001 'weight-decay 0.01)) adamw (nn/adamw 0.001 (Dictionary 'weight-decay 0.1)) rms (nn/rmsprop 0.01 (Dictionary 'alpha 0.5 'momentum 0.2))) (and (= (ref sgd 'kind) 'sgd) (= (ref sgd 'learning-rate) 0.1) (= (ref sgd 'momentum) 0.9) (= (ref sgd 'clip-norm) 1.0) (= (ref adam 'kind) 'adam) (= (ref adam 'beta1) 0.8) (= (ref adam 'beta2) 0.99) (= (ref adam 'epsilon) 0.000001) (= (ref adamw 'kind) 'adamw) (= (ref adamw 'weight-decay) 0.1) (= (ref rms 'kind) 'rmsprop) (= (ref rms 'alpha) 0.5) (= (ref rms 'momentum) 0.2)))", pass, fail);
    test_truthy(interp, "nn optimizer constructors validate ranges and option keys",
        "(and (= (handle (nn/sgd -0.1) (raise msg (ref msg 'code))) 'nn/invalid-spec) (= (handle (nn/sgd 0.1 (Dictionary 'beta1 0.9)) (raise msg (ref msg 'code))) 'nn/invalid-spec) (= (handle (nn/adam 0.001 (Dictionary 'beta1 1.0)) (raise msg (ref msg 'code))) 'nn/invalid-spec) (= (handle (nn/adamw 0.001 (Dictionary 'epsilon 0.0)) (raise msg (ref msg 'code))) 'nn/invalid-spec) (= (handle (nn/rmsprop 0.01 (Dictionary 'alpha 1.0)) (raise msg (ref msg 'code))) 'nn/invalid-spec))", pass, fail);
    test_truthy(interp, "nn/train-step accepts constructed optimizer specs",
        "(let (model (nn/init (nn/dense 2 1 (Dictionary 'kernel-init (Dictionary 'kind 'ones) 'bias-init (Dictionary 'kind 'zeros))) (Dictionary 'dtype 'Float64 'device 'cpu 'mode 'train 'seed 1)) step (nn/train-step model (Tensor Float64 [2] [1 2]) (Tensor Float64 [1] [4]) (nn/sgd 0.1 (Dictionary 'momentum 0.9)) (Dictionary)) weights (ref (ref (nn/parameters (ref step 'model)) 'weights) [0 0])) (< (abs (- weights 1.2)) 0.000000001))", pass, fail);
    test_truthy(interp, "Kernel constructor returns typed data with path access",
        "(let (k (Kernel (Dictionary 'backend 'vulkan 'operation 'elementwise 'inputs (Array (Dictionary 'name 'x 'dtype 'Float32 'shape (Array 'n))) 'outputs (Array (Dictionary 'name 'y 'dtype 'Float32 'shape (Array 'n))) 'push (Dictionary 'learning-rate 'Float32) 'workgroup (Array 64 1 1)))) (and (= (type-of k) 'Kernel) (is? k 'Kernel) (is? k 'Dictionary) (is? k 'Collection) (= (ref k 'kind) 'kernel) (= k.inputs.[0].name 'x) (= (ref k.outputs.[0].shape 0) 'n) (= (ref (ref k 'push) 'learning-rate) 'Float32)))", pass, fail);
    test_truthy(interp, "Kernel type overlay requires structural fields",
        "(and (= (type-of (Dictionary 'kind 'kernel)) 'Dictionary) (not (is? (Dictionary 'kind 'kernel) 'Kernel)))", pass, fail);
    test_truthy(interp, "Kernel validates keys output descriptors and workgroup",
