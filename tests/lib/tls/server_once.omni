(block
  (define port-str (default (getenv "OMNI_TLS_TEST_PORT") "45101"))
  (define cert (default (getenv "OMNI_TLS_TEST_CERT") "tests/lib/tls/server.cert.pem"))
  (define key (default (getenv "OMNI_TLS_TEST_KEY") "tests/lib/tls/server.key.pem"))
  (define p (parse-number port-str))
  (define ready-file (getenv "OMNI_TLS_READY_FILE"))
  (define done false)
  (define listener nil)
  (define sc nil)
  (define stls nil)
  (define watchdog
    (spawn (lambda ()
      (async-sleep 1500)
      (if done
          nil
          (block
            (if stls (try (lambda (ignored) (tls-close stls)) (lambda (e) nil)) nil)
            (if sc (try (lambda (ignored) (tcp-close sc)) (lambda (e) nil)) nil)
            (if listener (try (lambda (ignored) (tcp-close listener)) (lambda (e) nil)) nil)
            nil)))))
  (define server-fiber
    (spawn (lambda ()
      (set! listener (tcp-listen "127.0.0.1" p 8))
      (if ready-file (write-file ready-file "ready") nil)
      (set! sc (tcp-accept listener))
      (set! stls (tls-server-wrap sc cert key))
      (define req (try (lambda (ignored) (tls-read stls)) (lambda (e) nil)))
      (if (string? req)
          (try (lambda (ignored) (tls-write stls "pong")) (lambda (e) (if (and (dict? e) (has? e 'message)) (ref e 'message) e)))
          nil)
      (try (lambda (ignored) (tls-close stls)) (lambda (e) nil))
      (try (lambda (ignored) (tcp-close sc)) (lambda (e) nil))
      (try (lambda (ignored) (tcp-close listener)) (lambda (e) nil))
      (set! done true)
      nil)))
  (await server-fiber)
  (set! done true)
  (await watchdog))
