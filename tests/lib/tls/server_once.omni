(begin
  (define port-str (default (getenv "OMNI_TLS_TEST_PORT") "45101"))
  (define cert (default (getenv "OMNI_TLS_TEST_CERT") "tests/lib/tls/server.cert.pem"))
  (define key (default (getenv "OMNI_TLS_TEST_KEY") "tests/lib/tls/server.key.pem"))
  (define p (string->number port-str))
  (define listener (tcp-listen "127.0.0.1" p 8))
  (define sc (tcp-accept listener))
  (define stls (tls-server-wrap sc cert key))
  (define req (try-message (lambda (ignored) (tls-read stls)) (lambda (e) e)))
  (if (string? req)
      (try-message (lambda (ignored) (tls-write stls "pong")) (lambda (e) e))
      nil)
  (try-message (lambda (ignored) (tls-close stls)) (lambda (e) nil))
  (tcp-close sc)
  (tcp-close listener)
  nil)
