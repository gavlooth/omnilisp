;; boot_smoke.omni — bounded finwatch boot-path smoke (no run-fibers loop)
;; Run: LD_LIBRARY_PATH=/usr/local/lib ./build/main examples/finwatch/boot_smoke.omni

(import "server.omni" 'all)

(define req (decode-request "GET /health HTTP/1.1\nHost: local\n\n"))
(and (procedure? server/start)
     (and (= ('method req) "GET")
          (= ('path req) "/health")))
