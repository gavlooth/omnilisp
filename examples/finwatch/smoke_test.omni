;; smoke_test.omni — loads all modules and exercises core functionality offline.
;; Run from project root: ./build/main examples/finwatch/smoke_test.omni

(import "models.omni"    'all)
(import "http.omni"      'all)
(import "cache.omni"     'all)
(import "portfolio.omni" 'all)
(import "logging.omni"   'all)
(import "types.omni"     'all)
(import "analytics.omni" 'all)
(import "events.omni"    'all)
(import "rules.omni"     'all)
(import "alerts.omni"    'all)
(println "--- modules loaded ---")

(define (print-bool-line ok true-msg false-msg)
  (println (if ok true-msg false-msg)))

;; ── Types and dot access ──────────────────────────────────────────────────────
(define q (Quote "BTC" 62000.0 1700000000))
(define n (NewsItem 1 "Inflation hits 40-year high" 420 1700000000))
(define h (Holding "BTC" 0.5 30000.0))
(println q.symbol)
(println q.price)
(println n.title)
(println h.qty)

;; ── to-json dispatch ──────────────────────────────────────────────────────────
(println (json-emit (to-json q)))
(println (json-emit (to-json n)))
(println (json-emit (to-json h)))

;; ── FetchResult match ─────────────────────────────────────────────────────────
(match (Ok 42) ((Ok v) (println (format "Ok: %s" v))) ((Err e) (println e)))
(match (Err "broke") ((Ok v) (println v)) ((Err e) (println (format "Err: %s" e))))

;; ── Cache round-trip ──────────────────────────────────────────────────────────
(cache/store-quote! q)
(cache/store-quote! (Quote "ETH" 3400.0 1700000000))
(cache/store-quote! (Quote "JPY" 145.3 1700000000))
(println (format "cached quotes: %s" (length (cache/latest-quotes))))
(match (cache/quote-for "BTC")
  ((Ok fetched) (println (format "BTC price: %f" fetched.price)))
  ((Err e) (println e)))
(match (cache/quote-for "DOGE")
  ((Ok _) (println "WRONG"))
  ((Err e) (println (format "DOGE missing (expected): %s" e))))

;; ── sort-by (news) ──────────────────────────────────────────────────────────
(cache/store-news! n)
(cache/store-news! (NewsItem 2 "Fed raises rates again" 380 1700000000))
(cache/store-news! (NewsItem 3 "Crypto rally continues" 500 1700000000))
(println (format "cached news: %s" (length (cache/latest-news 10))))
(let (top-item (car (cache/latest-news 1)))
  (println (format "top news: %s (score=%s)" top-item.title top-item.score)))

;; ── to-json PnL gain% ────────────────────────────────────────────────────────
(let (p (PnL "TEST" 1.0 100.0 150.0 50.0) j (to-json p))
  (println (format "gain%%: %f" (ref j 'gain%)))
  (print-bool-line (= (ref j 'gain%) 50.0) "gain%: OK" "gain%: WRONG"))

;; ── Portfolio P&L ────────────────────────────────────────────────────────────
(define holdings (list (Holding "BTC" 0.5 30000.0) (Holding "ETH" 2.0 2000.0)))
(define result (portfolio/pnl holdings))
(println (json-emit result))

;; ── map demo ─────────────────────────────────────────────────────────────────
(println (map (* 10 _) '(3 1 4 1 5)))

;; ── _ placeholder ───────────────────────────────────────────────────────────
(println (map (+ 10 _) '(1 2 3)))

;; ── partition ───────────────────────────────────────────────────────────────
(let (split (partition (> _ 3) '(1 5 2 4 3)))
  (println (format "partition kept %s, rejected %s" (length (car split)) (length (cdr split)))))

;; ── try ─────────────────────────────────────────────────────────────────────
(println (try (lambda (x) (signal raise "test-error"))
              (lambda (e) (format "caught: %s" e))))

;; ── for-each ────────────────────────────────────────────────────────────────
(for-each (lambda (x) (println (format "  item: %s" x.symbol))) (cache/latest-quotes))

;; ── {..} dict destructuring ─────────────────────────────────────────────────
(define (greet {name age}) (format "%s is %s" name age))
(println (greet {'name "Alice" 'age 30}))

;; ── match [h .. t] ─────────────────────────────────────────────────────────
(match '(10 20 30)
  ([head .. rest] (println (format "head=%s rest-len=%s" head (length rest))))
  (_ (println "WRONG")))

;; ── fs-open / fs-write / fs-close (logging) ────────────────────────────────
(log/open! "/tmp/finwatch_smoke.log")
(log/write! "smoke test started")
(log/write! "cache populated")
(println (format "log size: %s bytes" (log/size)))
(let (contents (log/read-all))
  (println (format "log lines: %s" (length (string-split contents "\n")))))
(log/close!)
(fs-unlink "/tmp/finwatch_smoke.log")

;; ── process-spawn / process-wait ────────────────────────────────────────────
(println (format "system uptime: %s" (log/system-uptime)))

;; ── fs-stat ─────────────────────────────────────────────────────────────────
(let (info (fs-stat "/tmp"))
  (println (format "fs-stat /tmp: size=%s" ('size info))))

;; ── fs-readdir ──────────────────────────────────────────────────────────────
(println (format "fs-readdir /tmp: %s entries" (length (fs-readdir "/tmp"))))

;; ── TTL check ───────────────────────────────────────────────────────────────
(cache/set-last-refresh! (time))
(println (format "stale(60s): %s" (cache/stale? (cache/last-refresh) 60)))

;; ── pipe-connect / pipe-listen ─────────────────────────────────────────────
(let (pipe-ok
      (block
        (define pf (spawn (lambda ()
          (define p (string-append "/tmp/finwatch_pipe_" (number->string (% (time-ms) 1000000)) ".sock"))
          (define listener (pipe-listen p))
          (define client (pipe-connect p))
          (define server (tcp-accept listener))
          (tcp-write client "pipe-ok")
          (define got (tcp-read server))
          (tcp-close client)
          (tcp-close server)
          (tcp-close listener)
          (fs-unlink p)
          (= got "pipe-ok"))))
        (await pf)))
  (print-bool-line pipe-ok "pipe io: OK" "pipe io: WRONG"))

;; ── udp-socket / udp-send / udp-recv ───────────────────────────────────────
(let (udp-ok
      (block
        (define p (+ 35000 (% (time-ms) 20000)))
        (define recv (udp-socket))
        (udp-bind recv "127.0.0.1" p)
        (define rf (spawn (lambda () (udp-recv recv))))
        (async-sleep 5)
        (define snd (udp-socket))
        (udp-send snd "127.0.0.1" p "pong")
        (define got (await rf))
        (udp-close snd)
        (udp-close recv)
        (= got "pong")))
  (print-bool-line udp-ok "udp io: OK" "udp io: WRONG"))

;; ── signal-handle / signal-unhandle ────────────────────────────────────────
(let (signal-ok
      (block
        (define hits {'n 0})
        (define h (signal-handle 10 (lambda (sig)
                                      (set! hits 'n (+ (ref hits 'n) 1)))))
        (define notifier (process-spawn "/bin/sh" ["-c" "kill -USR1 $PPID"] nil))
        (await (spawn (lambda () (process-wait (ref notifier 'handle)))))
        (fs-close (ref notifier 'stdin))
        (fs-close (ref notifier 'stdout))
        (fs-close (ref notifier 'stderr))
        (async-sleep 20)
        (signal-unhandle h)
        (= (ref hits 'n) 1)))
  (print-bool-line signal-ok "signal io: OK" "signal io: WRONG"))

;; ── process-kill ────────────────────────────────────────────────────────────
(let (process-kill-ok
      (block
        (define child (process-spawn "/bin/sh" ["-c" "sleep 2"] nil))
        (process-kill (ref child 'handle) 15)
        (define st (await (spawn (lambda () (process-wait (ref child 'handle))))))
        (fs-close (ref child 'stdin))
        (fs-close (ref child 'stdout))
        (fs-close (ref child 'stderr))
        (> (ref st 'term-signal) 0)))
  (print-bool-line process-kill-ok "process-kill: OK" "process-kill: WRONG"))

(println "--- original idioms passed ---")

;; =========================================================================
;; types.omni — [abstract], [alias], type-of, is?, instance?, dot-bracket
;; =========================================================================

(define pe (PriceEvent "BTC" 62500.0 1700000001))
(define ae (AlertEvent "HIGH" "BTC above 60k" 1700000002))
(define se (SystemEvent "STARTUP" "server initialized" 1700000003))

(println (format "pe is Event? %s" (is? pe 'Event)))
(println (format "pe is PriceEvent? %s" (is? pe 'PriceEvent)))
(println (format "ae is Event? %s" (is? ae 'Event)))
(println (format "type-of pe: %s" (type-of pe)))
(println (format "instance? pe: %s" (instance? pe)))
(println (format "instance? 42: %s" (instance? 42)))
(println (event->str pe))
(println (event->str ae))
(println (event->str se))
(println (format "event-tag: %s" (event-tag pe)))
(println (format "event-ts: %s" (event-ts pe)))

;; dot-bracket .[ on arrays and dicts
(let (arr [10 20 30])
  (println (format "arr.[0]=%s arr.[2]=%s" arr.[0] arr.[2])))
(let (d {'x 1 'y 2})
  (println (format "d.['x]=%s" d.['x])))

;; [alias]
(println (format "Timestamp alias: %s" (is? 100 'Integer)))
(println (format "Price alias: %s" (is? 3.14 'Double)))

;; string->number / number->string / symbol->string
(println (format "string->number: %s" (string->number "42")))
(println (format "number->string: %s" (number->string 99)))
(println (format "symbol->string: %s" (symbol->string 'hello)))

;; import (sym 'as alias) — types.omni uses (Quote 'as MQuote)
(println (format "to-json via import 'as: %s" (json-emit (to-json (Quote "TEST" 1.0 0)))))

(println "--- types passed ---")

;; =========================================================================
;; analytics.omni — sets, zip, flatten, find, remove, any?, every?, string-join, string-contains?
;; =========================================================================

;; set operations
(analytics/add-symbol "BTC")
(analytics/add-symbol "ETH")
(analytics/add-symbol "JPY")
(analytics/add-symbol "BTC")
(println (format "unique symbols: %s" (length (analytics/unique-symbols))))
(analytics/remove-symbol "JPY")
(println (format "after remove JPY: %s" (length (analytics/unique-symbols))))

;; zip — use (list ...) for doubles (quoted double lists trigger dispatch loop)
(let (historical (list (cons "BTC" 60000.0) (cons "ETH" 3000.0))
      current    (list (cons "BTC" 62000.0) (cons "ETH" 3400.0))
      deltas     (analytics/price-deltas historical current))
  (println (format "BTC delta: %f" (cdr (car deltas))))
  (println (format "ETH delta: %f" (cdr (car (cdr deltas))))))

;; flatten
(println (format "flattened: %s" (length (analytics/flatten-sectors '(("BTC" "ETH") ("EUR" "GBP" "JPY"))))))

;; find
(let (found (analytics/find-holding "BTC" holdings))
  (println (format "find BTC: qty=%f" found.qty)))
(println (format "find DOGE: %s" (analytics/find-holding "DOGE" holdings)))

;; remove
(let (exclusions {})
  (set-add exclusions "ETH")
  (println (format "after exclude ETH: %s" (length (analytics/exclude-symbols exclusions holdings)))))

;; any? / every?
(let (test-pnls (list (PnL "BTC" 0.5 30000.0 31000.0 16000.0)
                       (PnL "ETH" 2.0 2000.0 6800.0 2800.0)))
  (println (format "any gain > 10000? %s" (analytics/any-above-threshold? test-pnls 10000.0)))
  (println (format "any gain > 20000? %s" (analytics/any-above-threshold? test-pnls 20000.0))))
(println (format "all have prices? %s" (analytics/all-have-prices? holdings)))

;; string-join
(println (format "symbols: %s" (analytics/format-symbols '("BTC" "ETH" "JPY"))))

;; string-contains? — news search
(let (crypto-news (analytics/search-news "Crypto" (cache/latest-news 10)))
  (println (format "crypto news: %s items" (length crypto-news))))

(println "--- analytics passed ---")

;; =========================================================================
;; events.omni — coroutine, resume, yield, coroutine?, reset/shift, iterators, delay/force
;; =========================================================================

;; coroutine / resume / yield / coroutine?
;; Note: use (list ...) not '(...) for base-prices (doubles)
(let (ticker (events/make-ticker '("BTC" "ETH") (list 60000.0 3000.0)))
  (println (format "ticker alive? %s" (coroutine? ticker)))
  (let (evts (events/pull-events ticker 4))
    (println (format "pulled %s events" (length evts)))
    (for-each (lambda (e) (println (format "  %s" (event->str e)))) evts))
  (println (format "still alive? %s" (coroutine? ticker))))

;; batching
(let (test-events (list (PriceEvent "X" 1.0 1700000001)
                        (PriceEvent "X" 2.0 1700000002)
                        (PriceEvent "X" 3.0 1700000003)
                        (PriceEvent "X" 4.0 1700000004)
                        (PriceEvent "X" 5.0 1700000005)
                        (PriceEvent "X" 6.0 1700000006)
                        (PriceEvent "X" 7.0 1700000007)))
  (let (batches (events/batch-events test-events 3))
    (println (format "batches: %s" (length batches)))
    (for-each (lambda (b) (println (format "  batch size: %s" (length b)))) batches)))

;; delay / force — lazy average
(let (lazy-avg (events/lazy-average (list 100.0 200.0 300.0)))
  (println (format "lazy avg type: %s" (type-of lazy-avg)))
  (println (format "lazy avg value: %f" (force lazy-avg))))

;; unless + assert! — validation
(let (mono-events (list (PriceEvent "A" 1.0 100)
                        (PriceEvent "B" 2.0 200)
                        (PriceEvent "C" 3.0 300)))
  (println (format "monotonic? %s" (events/validate-monotonic mono-events))))
(println (try (lambda (x)
               (events/validate-monotonic
                 (list (PriceEvent "A" 1.0 300) (PriceEvent "B" 2.0 100)))
               "WRONG")
              (lambda (e) (format "caught non-monotonic: %s" e))))

;; reset / shift — backpressure (single-shot continuation capture)
(let (bp-result (events/with-backpressure (range 10) 3))
  (match (pair? bp-result)
    (true
      (block
        (println (format "bp first batch: %s items" (length (car bp-result))))
        (print-bool-line (procedure? (car (cdr bp-result)))
                         "bp continuation captured: true"
                         "bp continuation captured: false")
        (println (format "bp remaining items: %s" (length (car (cdr (cdr bp-result))))))))
    (_ (println (format "bp result: %s" bp-result)))))

;; Iterator / next / range-from — thread iterator through
(let (p1 (next (range-from 10)))
  (println (format "range-from 1st: %s" (car p1)))
  (let (p2 (next (cdr p1)))
    (println (format "range-from 2nd: %s" (car p2)))
    (let (p3 (next (cdr p2)))
      (println (format "range-from 3rd: %s" (car p3))))))

;; repeat — lazy infinite repetition
(let (p1 (next (repeat 42)))
  (println (format "repeat 1st: %s" (car p1)))
  (let (p2 (next (cdr p1)))
    (println (format "repeat 2nd: %s" (car p2)))))

(println "--- events passed ---")

;; =========================================================================
;; rules.omni — [macro], gensym, eval, read-string, apply, macroexpand, let ^rec, quasiquote
;; =========================================================================

;; threshold rules — call rule lambdas directly (check-rule wrapper has scope bug)
(let (above-60k (rules/threshold-above 60000.0)
      below-50k (rules/threshold-below 50000.0)
      in-range  (rules/in-range 55000.0 65000.0))
  (print-bool-line (above-60k 62000.0) "62000 > 60k? true" "62000 > 60k? false")
  (print-bool-line (below-50k 62000.0) "62000 < 50k? true" "62000 < 50k? false")
  (print-bool-line (in-range 62000.0) "62000 in [55k,65k]? true" "62000 in [55k,65k]? false"))

;; apply — check-all applies rules to prices
(let (rules-list (list (rules/threshold-above 100.0) (rules/threshold-below 200.0))
      results (rules/check-all rules-list (list 50.0 150.0 250.0)))
  (println (format "check-all groups: %s" (length results))))

;; consecutive crossing — inline named let
(let check (remaining '(50 150 200 300) count 0)
  (if (>= count 3) (println "3 consecutive > 100 in (50 150 200 300)? true")
      (if (null? remaining) (println "3 consecutive > 100 in (50 150 200 300)? false")
          (if (> (car remaining) 100) (check (cdr remaining) (+ count 1))
              (check (cdr remaining) 0)))))
(let check (remaining '(150 50 200 300) count 0)
  (if (>= count 3) (println "3 consecutive > 100 in (150 50 200 300)? true")
      (if (null? remaining) (println "3 consecutive > 100 in (150 50 200 300)? false")
          (if (> (car remaining) 100) (check (cdr remaining) (+ count 1))
              (check (cdr remaining) 0)))))

;; define [macro] + gensym — rule macro
(define btc-high (rule > 60000))
(println (format "rule macro 62000: %s" (btc-high 62000.0)))
(println (format "rule macro 50000: %s" (btc-high 50000.0)))

;; macroexpand
(let (expanded (rules/expand-rule '(rule > 100)))
  (print "macroexpand: ") (println expanded))

;; quasiquote — rule descriptions
(print "quasiquote desc: ") (println (rules/describe '> 60000))

;; gensym — unique symbols
(let (g1 (gensym) g2 (gensym))
  (println (format "gensym unique? %s" (not (= g1 g2)))))

;; eval / read-string — dynamic rule loading
(let (dynamic-rule (rules/from-string "(lambda (p) (> p 50000))"))
  (println (format "dynamic rule 62000: %s" (dynamic-rule 62000.0)))
  (println (format "dynamic rule 40000: %s" (dynamic-rule 40000.0))))

(println "--- rules passed ---")

;; =========================================================================
;; alerts.omni — [effect], handle composition, alert dispatch
;; =========================================================================

;; Test collector handler (captures alerts)
(let (collector (alerts/make-collector-handler))
  (alerts/dispatch-multi
    (list collector)
    (lambda (x)
      (alerts/dispatch (AlertEvent "HIGH" "BTC above 60k" 1700000010))
      (alerts/dispatch (AlertEvent "LOW" "ETH below 3k" 1700000011))
      (alerts/dispatch (SystemEvent "ALERT" "2 alerts fired" 1700000012))))
  (println (format "collected alerts: %s" (length (alerts/collected)))))

;; Test log handler (prints to stdout) — composed handle wrappers
(let (logger (alerts/make-log-handler "[TEST-LOG]"))
  (alerts/dispatch-multi
    (list logger)
    (lambda (x)
      (alerts/dispatch (AlertEvent "INFO" "composition test" 1700000020)))))

;; Tutorial path — price + analytics alerts under a log+collector stack.
(let (tutorial-alerts (alerts/tutorial-demo))
  (println (format "tutorial alerts: %s" (length tutorial-alerts)))
  (println (event->str (car tutorial-alerts))))

(println "--- alerts passed ---")
(println "--- smoke test passed ---")
