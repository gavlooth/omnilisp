;; module_session_smoke.omni — verifies session-owned FTXUI runtime lifecycle
;; Run: LD_LIBRARY_PATH=/usr/local/lib ./build/main examples/libraries/ftxui/module_session_smoke.omni

(import "ui.omni")
(import ui)

(define (raise-message payload)
  (if (dict? payload)
      (String (ref payload 'message))
      (String payload)))

(define session-view
  (ui.window
    "Session"
    (ui.vbox
      (list
        (ui.text "session-runtime")
        (ui.button "increment" 'increment)
        (ui.text "incremental render/update smoke")))))

(define session-effects
  (ui.open_tree {'backend 'ftxui}
    (ui.render_tree {'node session-view})))

(define update-effects
  (ui.open_tree {'backend 'ftxui}
    (ui.invalidate_tree {'reason 'session-smoke})))

(define session (ui.open_session session-effects))
(define meta-before-close (foreign-describe session))
(define updated (ui.update_session session update-effects))
(define invalidated (ui.invalidate_session session))
(define rendered (ui.render_session session))
(define long-text "")
(define posted-first (ui.post_event_session session {'kind 'character 'text "x"}))
(define posted-second (ui.post_event_session session {'kind 'character 'text long-text}))
(define drained-first (ui.render_session session))
(define drained-second (ui.render_session session))
(define read-event (ui.read_event_session session))
(define read-event-second (ui.read_event_session session))
(define posted-return (ui.post_event_session session {'kind 'return}))
(define drained-return (ui.render_session session))
(define read-return-event (ui.read_event_session session))
(define read-button-message (ui.read_event_session session))

(define closed (ui.close_session session))
(define close-again (ui.close_session session))
(define meta-after-close (foreign-describe session))

(define render-after-close-error
  (handle
    (ui.render_session session)
    (raise msg (raise-message msg))))

(and (= (ref meta-before-close 'name) 'ui-ftxui-session)
     (= (ref meta-before-close 'live) true)
     (= updated session)
     (= invalidated session)
     (= posted-first session)
     (= posted-second session)
     (= rendered true)
     (= drained-first true)
     (= drained-second true)
     (= (ref read-event 'kind) 'character)
     (= (ref read-event 'text) "x")
     (= (ref read-event-second 'kind) 'character)
     (= (ref read-event-second 'text) long-text)
     (= posted-return session)
     (= drained-return true)
     (= (ref read-return-event 'kind) 'return)
     (= (ref read-button-message 'kind) 'special)
     (= (ref read-button-message 'text) "increment")
     (= closed true)
     (= close-again true)
     (= (ref meta-after-close 'live) nil)
     (= render-after-close-error "ui-ftxui.session: session handle is closed"))
