{
  "name": "tree-sitter-omni",
  "version": "0.1.0",
  "description": "Tree-sitter grammar scaffold for Omni Lisp",
  "license": "MIT",
  "main": "grammar.js",
  "keywords": [
    "parser",
    "tree-sitter",
    "omni",
    "omni-lisp",
    "lisp"
  ],
  "files": [
    "grammar.js",
    "queries",
    "tree-sitter.json"
  ],
  "scripts": {
    "generate": "tree-sitter generate",
    "parse": "tree-sitter parse --rebuild examples/sample.omni",
    "query:highlights": "tree-sitter query --captures queries/highlights.scm test/queries/highlights/canonical_forms.omni test/queries/highlights/legacy_forms.omni",
    "query:injections": "tree-sitter query --captures queries/injections.scm test/queries/highlights/canonical_forms.omni",
    "query:textobjects": "tree-sitter query --captures queries/textobjects.scm test/queries/structural_forms.omni",
    "query:locals": "tree-sitter query --captures queries/locals.scm test/queries/locals_forms.omni",
    "query:folds": "tree-sitter query --captures queries/folds.scm test/queries/structural_forms.omni",
    "query:indents": "tree-sitter query --captures queries/indents.scm test/queries/indents_forms.omni",
    "test": "tree-sitter test --rebuild",
    "test:update": "tree-sitter test --rebuild --update",
    "test:queries": "sh ./test/check_queries.sh"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.25.10"
  }
}
