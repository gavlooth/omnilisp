{
  "name": "tree-sitter-omni",
  "version": "0.1.0",
  "description": "Tree-sitter grammar scaffold for Omni Lisp",
  "license": "MIT",
  "main": "grammar.js",
  "keywords": [
    "parser",
    "tree-sitter",
    "omni",
    "omni-lisp",
    "lisp"
  ],
  "files": [
    "grammar.js",
    "queries",
    "tree-sitter.json"
  ],
  "scripts": {
    "generate": "npx --yes tree-sitter-cli@0.25.10 generate && bash ../../scripts/split_tree_sitter_parser.sh",
    "parse": "npx --yes tree-sitter-cli@0.25.10 parse --rebuild examples/sample.omni",
    "query:highlights": "npx --yes tree-sitter-cli@0.25.10 query --captures queries/highlights.scm test/queries/highlights/canonical_forms.omni test/queries/highlights/legacy_forms.omni",
    "query:injections": "npx --yes tree-sitter-cli@0.25.10 query --captures queries/injections.scm test/queries/highlights/canonical_forms.omni",
    "query:textobjects": "npx --yes tree-sitter-cli@0.25.10 query --captures queries/textobjects.scm test/queries/structural_forms.omni",
    "query:locals": "npx --yes tree-sitter-cli@0.25.10 query --captures queries/locals.scm test/queries/locals_forms.omni",
    "query:folds": "npx --yes tree-sitter-cli@0.25.10 query --captures queries/folds.scm test/queries/structural_forms.omni",
    "query:indents": "npx --yes tree-sitter-cli@0.25.10 query --captures queries/indents.scm test/queries/indents_forms.omni",
    "test": "npx --yes tree-sitter-cli@0.25.10 test --rebuild",
    "test:update": "npx --yes tree-sitter-cli@0.25.10 test --rebuild --update",
    "test:queries": "sh ./test/check_queries.sh"
  },
  "devDependencies": {
    "tree-sitter-cli": "0.25.10"
  }
}
